"""
OOP Snake Game - Lesson 3: Abstraction & Multiple Objects
Demonstrates: abstraction, encapsulation, multiple class instances
"""

import pygame
import sys
import random


class Snake:

    def __init__(self):
        # Store body in grid coordinates, not pixels
        self.grid_body = [(10, 5), (9, 5), (8, 5)]
        self.direction = 'STOPPED'
        self.change_to = self.direction

    def reset(self):
        # Store body in grid coordinates, not pixels
        self.grid_body = [(10, 5), (9, 5), (8, 5)]
        self.direction = 'STOPPED'
        self.change_to = self.direction
        

    def change_direction(self):
        if any((self.change_to == 'UP' and not self.direction == 'DOWN',
                self.change_to == 'DOWN' and not self.direction == 'UP',
                self.change_to == 'LEFT' and not self.direction == 'RIGHT',
                self.change_to == 'RIGHT' and not self.direction == 'LEFT')):
            self.direction = self.change_to

    def move(self):
        cx, cy = self.grid_body[0]

        if self.direction == 'UP':
            cy -= 1
        elif self.direction == 'DOWN':
            cy += 1
        elif self.direction == 'LEFT':
            cx -= 1
        elif self.direction == 'RIGHT':
            cx += 1
        elif self.direction == 'STOPPED':
            cx += 0
            cy += 0
        
        self.grid_body = [(cx, cy)] + self.grid_body[:-1]



    def grow(self):
        self.grid_body.append(self.grid_body[-1])

    def draw(self, surface, tile):
        for (cx, cy) in self.grid_body:
            pygame.draw.rect(surface, (0, 255, 0),
                             pygame.Rect(cx * tile, cy * tile, tile, tile))

    def check_collision(self, cols, rows):
        cx, cy = self.grid_body[0]

        if cx < 0 or cx >= cols or cy < 0 or cy >= rows:
            return True

        # if (cx, cy) in self.grid_body[1:]:
        #     return True

        return False

class Wall:

    def __init__(self, cols, rows):
        self.spawn(cols, rows)

    def spawn(self, cols, rows):

        center_x = cols // 2
        center_y = rows // 2

        # Vertical wall made of tiles
        self.grid_positions = []

        for i in range(-8, 9):
            self.grid_positions.append((center_x, center_y + i))

    def reset_wall_pos(self, cols, rows):
        self.spawn(cols, rows)

    def draw(self, surface, tile):

        for (cx, cy) in self.grid_positions:
            pygame.draw.rect(
                surface,
                (255, 255, 255),
                pygame.Rect(cx * tile, cy * tile, tile, tile)
            )

class Food:

    def __init__(self, cols, rows):
        self.grid_pos = (random.randint(0, cols - 1),
                         random.randint(0, rows - 1))

    def spawn(self, cols, rows):
        self.grid_pos = (random.randint(0, cols - 1),
                         random.randint(0, rows - 1))

    def draw(self, surface, tile):
        cx, cy = self.grid_pos
        pygame.draw.rect(surface, (255, 0, 0),
                         pygame.Rect(cx * tile, cy * tile, tile, tile))
        
class Cheese:

    def __init__(self, cols, rows):
        self.grid_pos = (random.randint(0, cols - 1),
                         random.randint(0, rows - 1))

    def spawn(self, cols, rows):
        self.grid_pos = (random.randint(0, cols - 1),
                         random.randint(0, rows - 1))

    def draw(self, surface, tile):
        cx, cy = self.grid_pos
        pygame.draw.rect(surface, (255, 255, 0),
                         pygame.Rect(cx * tile, cy * tile, tile, tile))
        # pygame.draw.li(surface, (255, 255, 0), )



def game_loop():

    pygame.init()
    #width, height = 640, 480
    # width, height = 1280, 720
    # width, height = 0, 0
    # window = pygame.display.set_mode((width, height), pygame.RESIZABLE)

# Get current monitor resolution
    info = pygame.display.Info()
    width, height = info.current_w, info.current_h

# Create fullscreen window
    window = pygame.display.set_mode((width, height), pygame.FULLSCREEN)
    
    pygame.display.set_caption("Snake Game")
    clock = pygame.time.Clock()
    

    # Tile size is derived from window size — 64 columns fits nicely at 640px
    def get_tile(w, h):
        return max(8, min(w, h) // 48)

    def get_grid(w, h, tile):
        return w // tile, h // tile

    tile = get_tile(width, height)
    cols, rows = get_grid(width, height, tile)

    snake = Snake()
    food = Food(cols, rows)
    cheese = Cheese(cols, rows)
    wall = Wall(cols, rows)


    foodfake = Food(cols, rows)

    font = pygame.font.SysFont('Arial', 24)
    boosting = False
    score = 0
    score_old = 0
    counter1 = 0
    highscore = 0


    start = True
    gameover = False

    while True:

        # Recalculate tile and grid every frame so resizing is instant
        width, height = window.get_size()
        tile = get_tile(width, height)
        cols, rows = get_grid(width, height, tile)

        score_divided = score // 1000

        

        if gameover == False:
            score_divided = score // 1000
            if boosting and score > 0:
                tick = 15 + (score_divided // 5) * 2 + 50
                score -= 100
            else:
                tick = 15 + (score_divided // 5) * 2
        elif gameover == True:
            tick = 0


            

        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                pygame.quit()
                sys.exit()
            elif event.type == pygame.KEYDOWN:
                if event.key == pygame.K_UP or event.key == pygame.K_w:
                    snake.change_to = 'UP'
                elif event.key == pygame.K_DOWN or event.key == pygame.K_s:
                    snake.change_to = 'DOWN'
                elif event.key == pygame.K_LEFT or event.key == pygame.K_a:
                    snake.change_to = 'LEFT'
                elif event.key == pygame.K_RIGHT or event.key == pygame.K_d:
                    snake.change_to = 'RIGHT'
                elif event.key == pygame.K_ESCAPE:
                    pygame.quit()
                    sys.exit()



                elif event.key == pygame.K_SPACE:
                    boosting = True
                    if start == True:
                        snake.change_to = 'RIGHT'
                        start = False
                    elif gameover:
                        start = True
                        gameover = False

                        #Reset Snake to Start Position
                        snake.reset()

                        #Zero All Scores
                        score = 0
                        score_divided = 0
                        score_old = 0

                        

                    

            elif event.type == pygame.KEYUP:
                if event.key == pygame.K_SPACE:
                    boosting = False

        if not start and not gameover:
            snake.change_direction()
            snake.move()

        if snake.grid_body[0] == food.grid_pos:
            snake.grow()
            food.spawn(cols, rows)
            foodfake.spawn(cols, rows)
            

            if boosting:
                score += 3000
                score_old += 3
            else:
                score += 1000
                score_old += 1

        if snake.grid_body[0] in wall.grid_positions:
            gameover = True
            

        if snake.grid_body[0] == cheese.grid_pos:
            snake.grow()
            cheese.spawn(cols, rows)

            if boosting:
                score += 8000
                score_old += 8
            else:
                score += 4000
                score_old += 4

        if snake.check_collision(cols, rows):
            gameover = True
            # pygame.quit()
            # sys.exit()

        escape_font = pygame.font.SysFont('Arial', 20)

        
        if start:

            window.fill((0,0,0))

            start_font = pygame.font.SysFont('Arial', max(40, tile * 2))
            start_text = start_font.render(f'Press Space to Start',True, (255,255,255))
            
            window.blit(start_text, (width // 2 - start_text.get_width() // 2, height // 2 - 60))
            #print(f"Cols: {width}, Rows: {height}")
            escape_text = escape_font.render("Press ESC To Exit", True, (255,255,255))
            window.blit(escape_text, (10,10))
        elif gameover:
            counter1 += 1
            if score_old > highscore:
                highscore = score_old

            window.fill((0, 0, 0))

            gameover_font = pygame.font.SysFont('papyrus', max(60, tile * 4))
            gameover_text = gameover_font.render('GAME OVER. Press Space to restart', True, (180, 0, 0))
            gameover_text1 = gameover_font.render('Or wait till the game closes', True, (180, 0, 0))


            score_font = pygame.font.SysFont('papyrus', max(28, tile * 2))
            score_text = score_font.render(f'Score: {score_old}', True, (140, 0, 0))

            highscore_text = score_font.render(f'Highscore: {highscore}', True, (140, 0, 0))



            window.blit(gameover_text, (width // 2 - gameover_text.get_width() // 2, height // 2 - 60))
            window.blit(gameover_text1, (width // 2 - gameover_text1.get_width() // 2, height // 2 ))

            window.blit(highscore_text,    (width // 2 - highscore_text.get_width() // 2,    height // 2 + 108))
            window.blit(score_text,(width // 2 - score_text.get_width() // 2,    height // 2 + 80))
            escape_text = escape_font.render("Press ESC To Exit", True, (255,255,255))
            window.blit(escape_text, (10,10))

            print(f"Counter: {counter1}")

            if counter1 > 1500:
                pygame.quit()
                sys.exit()

        else:
            window.fill((0, 0, 0))
            snake.draw(window, tile)
            food.draw(window, tile)

            # Uncomment This for fake food
            #foodfake.draw(window, tile)

            cheese.draw(window, tile)
            wall.draw(window, tile)
            font = pygame.font.SysFont('Arial', max(12, tile * 2))
            score_text = font.render(f'Score: {score / 1000} Score No Boost: {score_old}', True, (255, 255, 255))
            window.blit(score_text, (10, 10))

        pygame.display.flip()
        clock.tick(tick)

if __name__ == "__main__":
    game_loop()