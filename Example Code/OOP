import pygame
import sys

pygame.init()

# --- Snake class (encapsulation) ---
class Snake:
    def __init__(self, x, y):
        self.segments = [(x, y)]  # Private data
        self.direction = 'STOPPED'
        self.color = (0, 0, 255)

    def move(self):
        """Encapsulated movement logic"""
        head_x, head_y = self.segments[0]

        if self.direction == 'RIGHT':
            head_x += 20
        elif self.direction == 'LEFT':
            head_x -= 20
        elif self.direction == 'UP':
            head_y -= 20
        elif self.direction == 'DOWN':
            head_y += 20
        elif self.direction == "STOPPED":
            head_x += 0

        # Add new head, remove tail
        self.segments.insert(0, (head_x, head_y))
        self.segments.pop()

    def change_direction(self, new_direction):
        """Controlled access to direction"""
        # Prevent reversing directly
        opposites = {'UP': 'DOWN', 'DOWN': 'UP',
                     'LEFT': 'RIGHT', 'RIGHT': 'LEFT'}
        if new_direction != opposites.get(self.direction):
            self.direction = new_direction

    def draw(self, window):
        """Encapsulated drawing logic"""
        for segment in self.segments:
            pygame.draw.ellipse(window, self.color,
                           (*segment, 20, 20))

# Set up display
width, height = 640, 480
window = pygame.display.set_mode((width, height))
pygame.display.set_caption("Snake Game - OOP")
clock = pygame.time.Clock()

# Create a snake object
snake = Snake(width // 2, height // 2)

# Main loop
while True:
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            pygame.quit()
            sys.exit()
        elif event.type == pygame.KEYDOWN:
            if event.key == pygame.K_UP or pygame.K_w:
                snake.change_direction('UP')
            elif event.key == pygame.K_DOWN or pygame.K_s:
                snake.change_direction('DOWN')
            elif event.key == pygame.K_LEFT or pygame.K_a:
                snake.change_direction('LEFT')
            elif event.key == pygame.K_RIGHT or pygame.K_d:
                snake.change_direction('RIGHT')
            # elif event.key == pygame.K_KP_ENTE

    snake.move()

    window.fill((0, 0, 0))
    snake.draw(window)
    pygame.display.flip()
    clock.tick(20)